generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Perfil {
  ADMINISTRADOR
  JURIDICO
  ADMINISTRATIVO
  CONSULTA
}

enum TipoProcesso {
  JURIDICO
  ADMINISTRATIVO
}

enum StatusProcesso {
  ABERTO
  EM_ANALISE
  AGUARDANDO_PARECER
  EM_ANDAMENTO
  ENCAMINHADO
  CONCLUIDO
  ARQUIVADO
  CANCELADO
}

enum Prioridade {
  BAIXA
  NORMAL
  ALTA
  URGENTE
}

enum TipoMovimentacao {
  PARECER
  DESPACHO
  MOVIMENTACAO_INTERNA
  ATUALIZACAO_STATUS
  OBSERVACAO
  ENCAMINHAMENTO
}

model Usuario {
  id           String   @id @default(cuid())
  nome         String
  email        String   @unique
  senhaHash    String   @map("senha_hash")
  perfil       Perfil   @default(CONSULTA)
  ativo        Boolean  @default(true)
  criadoEm    DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  processosCriados Processo[]           @relation("ProcessoCriadoPor")
  movimentacoes    MovimentacaoProcesso[]
  logs             LogSistema[]

  @@map("usuarios")
}

model Processo {
  id               String         @id @default(cuid())
  numeroProcesso   String         @unique @map("numero_processo")
  tipoProcesso     TipoProcesso   @map("tipo_processo")
  assunto          String
  descricaoInicial String         @map("descricao_inicial") @db.Text
  requerente       String
  setorResponsavel String         @map("setor_responsavel")
  status           StatusProcesso @default(ABERTO)
  prioridade       Prioridade     @default(NORMAL)
  dataAbertura     DateTime       @map("data_abertura")
  observacoes      String?        @db.Text
  ativo            Boolean        @default(true)
  criadoPor        String         @map("criado_por")
  criadoEm         DateTime       @default(now()) @map("criado_em")
  atualizadoEm     DateTime       @updatedAt @map("atualizado_em")

  usuario       Usuario               @relation("ProcessoCriadoPor", fields: [criadoPor], references: [id])
  movimentacoes MovimentacaoProcesso[]

  @@map("processos")
}

model MovimentacaoProcesso {
  id               String           @id @default(cuid())
  processoId       String           @map("processo_id")
  tipoMovimentacao TipoMovimentacao @map("tipo_movimentacao")
  descricao        String           @db.Text
  parecer          String?          @db.Text
  statusAnterior   StatusProcesso?  @map("status_anterior")
  statusNovo       StatusProcesso?  @map("status_novo")
  criadoPor        String           @map("criado_por")
  criadoEm         DateTime         @default(now()) @map("criado_em")

  processo Processo @relation(fields: [processoId], references: [id])
  usuario  Usuario  @relation(fields: [criadoPor], references: [id])

  @@map("movimentacoes_processo")
}

model LogSistema {
  id         String   @id @default(cuid())
  usuarioId  String   @map("usuario_id")
  acao       String
  entidade   String
  entidadeId String?  @map("entidade_id")
  detalhes   Json?
  criadoEm   DateTime @default(now()) @map("criado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("logs_sistema")
}
